@page
@model WEB.Pages.Productos.IndexModel
@{
}
<h1>Listado de Productos</h1>

    <div class="container">
        
        <div class="text-center mb-4">
            <a type="button" class="btn btn-group-lg btn-primary btn-lg" asp-page="./Agregar"><i class="bi bi-plus-square"></i> Agregar</a>
        </div>
    <div class="row">
        @if (Model.productos != null && Model.productos.Any())
        {
            @foreach (var producto in Model.productos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-body">

                            <h5 class="card-title">
                                @producto.Nombre
                            </h5>

                            <h6 class="card-subtitle mb-2 text-muted">
                                Categoría: @producto.Categoria
                            </h6>

                            <p class="card-text">
                                @producto.Descripcion
                            </p>

                            <p><strong>Precio:</strong> ₡ @producto.Precio</p>
                            

                            <a class="btn btn-primary"
                               asp-page="./Detalle"
                               asp-route-id="@producto.Id">
                                <i class="bi bi-info-square"></i> Detalle
                            </a>

                            <a class="btn btn-warning"
                               asp-page="./Editar"
                               asp-route-id="@producto.Id">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>

                            <a class="btn btn-danger"
                               asp-page="./Eliminar"
                               asp-route-id="@producto.Id">
                                <i class="bi bi-trash3-fill"></i> Eliminar
                            </a>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning" role="alert">
                No hay productos disponibles.
            </div>
        }
    </div>
    </div>